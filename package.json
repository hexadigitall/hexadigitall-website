{
  "name": "hexadigitall",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "preinstall": "node scripts/check-node-version.mjs",
    "check:critical": "node scripts/check-critical-files.mjs",
    "fix:critical": "node scripts/check-critical-files.mjs --fix",
    "og:generate": "node scripts/generate-og-images.mjs",
    "og:generate:courses": "node scripts/generate-og-course-images.mjs",
    "dev": "node scripts/check-critical-files.mjs --fix && cross-env NEXT_DISABLE_TURBOPACK=1 CHOKIDAR_USEPOLLING=1 CHOKIDAR_INTERVAL=120 WATCHPACK_POLLING=true next dev --webpack",
    "dev:turbo": "next dev --turbopack",
    "dev:poll": "cross-env NEXT_DISABLE_TURBOPACK=1 CHOKIDAR_USEPOLLING=1 CHOKIDAR_INTERVAL=120 WATCHPACK_POLLING=true next dev --webpack",
    "dev:poll:clean": "rm -rf .next && cross-env NEXT_DISABLE_TURBOPACK=1 CHOKIDAR_USEPOLLING=1 CHOKIDAR_INTERVAL=120 WATCHPACK_POLLING=true next dev --webpack",
    "dev:fast": "cross-env NODE_ENV=development next dev --turbopack --experimental-https",
    "clean:install": "rm -rf node_modules && npm ci",
    "rebuild:native": "npm rebuild sharp canvas || (npm rebuild sharp --build-from-source && npm rebuild canvas --build-from-source)",
    "build": "next build",
    "build:analyze": "cross-env ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint",
    "create-sample-services": "node scripts/create-sample-services.js",
    "import-service-categories": "node import-service-categories.js",
    "import-sample-content": "node import-sample-content.js",
    "check-sanity-content": "node check-sanity-content.js",
    "fix-faq-keys": "node fix-faq-keys.js",
    "recreate-faqs": "node fix-faq-keys.js recreate",
    "fix-blog-keys": "node fix-blog-keys.js",
    "cleanup-duplicates": "node cleanup-duplicates.js",
    "fix-remaining-issues": "node fix-remaining-issues.js",
    "final-cleanup": "node final-cleanup.js",
    "update-service-overviews": "node update-service-overviews.js",
    "complete-course-rebuild": "node complete-course-rebuild.js",
    "force-cleanup-courses": "node force-cleanup-courses.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "validate-services": "node scripts/validate-service-data.js",
    "migrate": "ts-node scripts/migrate-services.ts",
    "migrate:dry-run": "cross-env DRY_RUN=true ts-node scripts/migrate-services.ts",
    "migrate:dry-run:compiled": "tsc --project scripts/tsconfig.json --outDir .build-scripts && node .build-scripts/migrate-services-dryrun.js",
    "migrate:courses": "node scripts/migrate-courses-regional.js",
    "migrate:courses:validate": "node scripts/validate-migration-readiness.js",
    "curriculum:import": "node scripts/import-curriculums-to-sanity.mjs"
  },
  "dependencies": {
    "@esbuild/linux-x64": "^0.28.0",
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@portabletext/react": "^6.2.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@sanity/client": "^7.22.0",
    "@sanity/image-url": "^2.1.1",
    "@sanity/vision": "^5.26.0",
    "@sparticuz/chromium": "^148.0.0",
    "canvas": "^3.2.3",
    "cheerio": "^1.2.0",
    "docx": "^9.6.1",
    "dotenv": "^17.4.2",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.40.0",
    "fs-extra": "^11.3.5",
    "lottie-react": "^2.4.1",
    "next-auth": "^4.24.14",
    "next-sanity": "^13.0.3",
    "node-fetch": "^3.3.2",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^25.0.4",
    "puppeteer-core": "^25.0.4",
    "qrcode": "^1.5.4",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "react-parallax-tilt": "^1.7.328",
    "resend": "^6.12.3",
    "rxjs": "^7.8.2",
    "styled-components": "^6.4.2"
  },
  "overrides": {
    "simple-swizzle": "0.2.2",
    "lodash": "4.18.0",
    "lodash-es": "4.18.0",
    "@actions/http-client": {
      "undici": "^6.23.0"
    },
    "@actions/github": {
      "undici": "^6.23.0"
    }
  },
  "optionalDependencies": {
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@jest/globals": "^30.4.1",
    "@next/bundle-analyzer": "^16.2.6",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/next": "^8.0.7",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "baseline-browser-mapping": "^2.10.31",
    "critters": "^0.0.23",
    "cross-env": "^10.0.0",
    "eslint": "^10.4.0",
    "eslint-config-next": "^16.2.6",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "next": "^16.2.6",
    "postcss": "^8.5.15",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sanity": "^5.26.0",
    "tailwindcss": "^4.3.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
